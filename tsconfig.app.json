{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "declaration": true,
    "emitDeclarationOnly": false,
    "rootDir": "src",
    "outDir": "./dist",
    "declarationDir": "./dist",
    "tsBuildInfoFile": "../../dist/libs/config.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../types"
    },
    {
      "path": "../utils"
    }
  ]
}
